generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  TECHNICIAN
  DISPATCHER
  CSR
  INSTALLER
  COMFORT_ADVISOR
  EMPLOYEE
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  fullName     String
  employeeId   String?  @unique
  role         Role     @default(EMPLOYEE)
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
  avatar       String?

  // Relations
  acknowledgements   Acknowledgement[]
  readRecords        ReadRecord[]
  quizAttempts       QuizAttempt[]
  trainingProgress   TrainingProgress[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  createdArticles    Article[]          @relation("ArticleAuthor")
  createdPolicies    Policy[]           @relation("PolicyAuthor")
  createdAnnouncements Announcement[]   @relation("AnnouncementAuthor")
  createdQuizzes     Quiz[]             @relation("QuizAuthor")

  @@map("users")
}

// ─────────────────────────────────────────────
// COMPANY BIBLE / KNOWLEDGE BASE
// ─────────────────────────────────────────────

enum CategoryDept {
  SALES
  SERVICE
  INSTALLATION
  DISPATCH
  CUSTOMER_SERVICE
  SAFETY
  HUMAN_RESOURCES
  MARKETING
  ACCOUNTING
  MANAGEMENT
  GENERAL
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  dept        CategoryDept @default(GENERAL)
  icon        String?
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  articles Article[]
  policies Policy[]
  sops     SOP[]

  @@map("categories")
}

enum ContentType {
  ARTICLE
  SOP
  POLICY
  INCIDENT_GUIDE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  content      String        // Rich text / markdown
  contentType  ContentType   @default(ARTICLE)
  status       ContentStatus @default(DRAFT)
  categoryId   String
  authorId     String
  isSample     Boolean       @default(false)
  requiresAck  Boolean       @default(false)
  viewCount    Int           @default(0)
  tags         String[]      @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  publishedAt  DateTime?

  category     Category       @relation(fields: [categoryId], references: [id])
  author       User           @relation("ArticleAuthor", fields: [authorId], references: [id])
  readRecords  ReadRecord[]
  attachments  Attachment[]

  @@map("articles")
}

model SOP {
  id                String        @id @default(uuid())
  title             String
  slug              String        @unique
  purpose           String
  whenToUse         String
  requiredMaterials String[]      @default([])
  requiredTools     String[]      @default([])
  steps             Json          // Array of {order, title, description, warning?, tip?}
  commonMistakes    String[]      @default([])
  escalationProcess String?
  relatedPolicies   String[]      @default([])
  status            ContentStatus @default(DRAFT)
  categoryId        String
  authorId          String
  isSample          Boolean       @default(false)
  requiresAck       Boolean       @default(false)
  viewCount         Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  publishedAt       DateTime?

  category    Category     @relation(fields: [categoryId], references: [id])
  attachments Attachment[]
  readRecords ReadRecord[]

  @@map("sops")
}

// ─────────────────────────────────────────────
// POLICIES WITH VERSIONING
// ─────────────────────────────────────────────

model Policy {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  categoryId  String
  authorId    String
  isSample    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category  Category        @relation(fields: [categoryId], references: [id])
  author    User            @relation("PolicyAuthor", fields: [authorId], references: [id])
  versions  PolicyVersion[]

  @@map("policies")
}

model PolicyVersion {
  id            String        @id @default(uuid())
  policyId      String
  version       String        // e.g. "1.0", "1.1", "2.0"
  content       String
  status        ContentStatus @default(DRAFT)
  effectiveDate DateTime?
  changeReason  String?
  requiresAck   Boolean       @default(false)
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  publishedAt   DateTime?

  policy           Policy            @relation(fields: [policyId], references: [id])
  acknowledgements Acknowledgement[]
  readRecords      ReadRecord[]

  @@map("policy_versions")
}

// ─────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────

enum AnnouncementPriority {
  NORMAL
  IMPORTANT
  CRITICAL
}

model Announcement {
  id           String               @id @default(uuid())
  title        String
  content      String
  priority     AnnouncementPriority @default(NORMAL)
  authorId     String
  requiresAck  Boolean              @default(false)
  targetRoles  Role[]               @default([])  // empty = all roles
  isActive     Boolean              @default(true)
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  publishedAt  DateTime?

  author           User              @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  acknowledgements Acknowledgement[]
  readRecords      ReadRecord[]

  @@map("announcements")
}

// ─────────────────────────────────────────────
// ACKNOWLEDGEMENTS & DIGITAL SIGNATURES
// ─────────────────────────────────────────────

enum AckContentType {
  POLICY_VERSION
  ANNOUNCEMENT
  ARTICLE
  SOP
}

model Acknowledgement {
  id              String         @id @default(uuid())
  userId          String
  contentType     AckContentType
  contentId       String         // polymorphic: policyVersionId, announcementId, etc.
  policyVersionId String?
  announcementId  String?
  articleId       String?        // for articles requiring ack
  
  // Digital signature fields
  fullName        String
  employeeId      String?
  signatureData   String         // base64 drawn signature or typed name hash
  ipAddress       String?
  userAgent       String?
  deviceInfo      String?
  
  acknowledgedAt  DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id])
  policyVersion PolicyVersion? @relation(fields: [policyVersionId], references: [id])
  announcement  Announcement?  @relation(fields: [announcementId], references: [id])

  @@unique([userId, contentType, contentId])
  @@map("acknowledgements")
}

// ─────────────────────────────────────────────
// READ TRACKING
// ─────────────────────────────────────────────

enum ReadContentType {
  ARTICLE
  SOP
  POLICY_VERSION
  ANNOUNCEMENT
}

model ReadRecord {
  id            String          @id @default(uuid())
  userId        String
  contentType   ReadContentType
  contentId     String
  articleId     String?
  sopId         String?
  policyVersionId String?
  announcementId  String?
  firstViewedAt DateTime        @default(now())
  lastViewedAt  DateTime        @default(now())
  viewCount     Int             @default(1)
  timeSpentSecs Int             @default(0)

  user          User           @relation(fields: [userId], references: [id])
  article       Article?       @relation(fields: [articleId], references: [id])
  sop           SOP?           @relation(fields: [sopId], references: [id])
  policyVersion PolicyVersion? @relation(fields: [policyVersionId], references: [id])
  announcement  Announcement?  @relation(fields: [announcementId], references: [id])

  @@unique([userId, contentType, contentId])
  @@map("read_records")
}

// ─────────────────────────────────────────────
// TRAINING SYSTEM
// ─────────────────────────────────────────────

model TrainingTrack {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  targetRole  Role?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules  TrainingModule[]
  progress TrainingProgress[]

  @@map("training_tracks")
}

enum ModuleType {
  READING
  VIDEO
  QUIZ
  ACKNOWLEDGEMENT
}

model TrainingModule {
  id          String     @id @default(uuid())
  trackId     String
  title       String
  description String?
  type        ModuleType
  contentId   String?    // links to article/sop/quiz id
  contentUrl  String?    // for videos
  order       Int        @default(0)
  isRequired  Boolean    @default(true)
  createdAt   DateTime   @default(now())

  track    TrainingTrack      @relation(fields: [trackId], references: [id])
  progress TrainingProgress[]

  @@map("training_modules")
}

model TrainingProgress {
  id          String    @id @default(uuid())
  userId      String
  trackId     String
  moduleId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  score       Int?      // for quizzes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User           @relation(fields: [userId], references: [id])
  track  TrainingTrack  @relation(fields: [trackId], references: [id])
  module TrainingModule @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
  @@map("training_progress")
}

// ─────────────────────────────────────────────
// QUIZZES
// ─────────────────────────────────────────────

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  authorId    String
  passingScore Int     @default(80)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author    User          @relation("QuizAuthor", fields: [authorId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  question      String
  options       Json     // Array of {id, text}
  correctOption String
  explanation   String?
  order         Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  quizId      String
  answers     Json     // {questionId: selectedOptionId}
  score       Int
  passed      Boolean
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])

  @@map("quiz_attempts")
}

// ─────────────────────────────────────────────
// MEDIA & ATTACHMENTS
// ─────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  PDF
  AUDIO
  DOCUMENT
  OTHER
}

model Attachment {
  id        String    @id @default(uuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  mediaType MediaType @default(OTHER)
  articleId String?
  sopId     String?
  createdAt DateTime  @default(now())

  article Article? @relation(fields: [articleId], references: [id])
  sop     SOP?     @relation(fields: [sopId], references: [id])

  @@map("attachments")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

enum NotificationType {
  NEW_ANNOUNCEMENT
  POLICY_UPDATE
  ACK_REQUIRED
  TRAINING_ASSIGNED
  QUIZ_RESULT
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
